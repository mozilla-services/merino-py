# Local developer overrides — copy to default.local.toml and edit as needed.
# This file is committed. default.local.toml is gitignored.
# Dynaconf loads default.local.toml automatically alongside default.toml.

[default.providers.sports.es]
# DSN for local Elasticsearch (see dev/docker-compose.yaml)
dsn = "http://localhost:9200"
# api_key is required by ElasticCredentials.validate() but ignored by ES
# when xpack.security.enabled=false (the local docker-compose default)
api_key = "local"
